# Copy to .env on the Proxmox VM. Do not commit the populated file.
APP_DOMAIN=crm.example.invalid
HOOKS_DOMAIN=hooks.example.invalid
KEYCLOAK_DOMAIN=auth.example.invalid
GRAFANA_DOMAIN=observability.example.invalid
CLOUDFLARE_API_TOKEN=replace-with-zone-scoped-dns-token

POSTGRES_DB=legal_crm
# Bootstrap is used only to initialize the empty volume and must never appear in an application URL.
POSTGRES_BOOTSTRAP_USER=legal_crm_bootstrap
POSTGRES_BOOTSTRAP_PASSWORD=replace-with-long-random-password
POSTGRES_MIGRATION_USER=legal_crm_migrator
POSTGRES_MIGRATION_PASSWORD=replace-with-long-random-password
POSTGRES_RUNTIME_USER=legal_crm_runtime
POSTGRES_RUNTIME_PASSWORD=replace-with-long-random-password
POSTGRES_PLATFORM_USER=legal_crm_platform
POSTGRES_PLATFORM_PASSWORD=replace-with-long-random-password
POSTGRES_REPORTING_USER=legal_crm_reporting
POSTGRES_REPORTING_PASSWORD=replace-with-long-random-password
POSTGRES_KEYCLOAK_USER=keycloak
POSTGRES_KEYCLOAK_PASSWORD=replace-with-long-random-password
REDIS_PASSWORD=replace-with-long-random-password
KEYCLOAK_ADMIN=platform-admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-long-random-password
NEXTAUTH_URL=https://crm.example.invalid
NEXTAUTH_SECRET=replace-with-32-byte-or-longer-random-secret
KEYCLOAK_CLIENT_ID=legal-crm-web
KEYCLOAK_CLIENT_SECRET=replace-with-keycloak-client-secret
INFERENCE_WORKER_TOKEN=replace-with-worker-to-server-token
INFERENCE_WORKER_ACTOR_ID=10000000-0000-4000-8000-000000000020
# Server-managed provider subscription/channel mappings. Keep real secrets out of source control;
# production values must be sourced from the approved OpenBao secret bootstrap.
WEBHOOK_TRUSTED_MAPPINGS=[]
MINIO_ROOT_USER=minio-admin
MINIO_ROOT_PASSWORD=replace-with-long-random-password
# The platform worker receives only this scanner principal. It may read exact document
# versions, never list, write, delete, or administer buckets/users.
MINIO_DOCUMENT_BUCKET=legal-documents
MINIO_DOCUMENT_RETENTION_DAYS=365
MINIO_SCANNER_ACCESS_KEY=document-scanner
MINIO_SCANNER_SECRET_KEY=replace-with-long-random-password
OPENBAO_ADDR=http://openbao:8200
# Obtain this from the OpenBao workload auth bootstrap process; it is short-lived and scoped.
OPENBAO_TOKEN=replace-with-scoped-short-lived-runtime-token

# Release image references are supplied by CI/CD; do not use floating tags in production.
WEB_IMAGE=ghcr.io/replace-me/legal-crm-web:replace-me
PLATFORM_WORKER_IMAGE=ghcr.io/replace-me/legal-crm-platform-worker:replace-me
MIGRATOR_IMAGE=local/legal-crm-migrator:24.18.0
OTEL_EXPORTER_OTLP_ENDPOINT=
