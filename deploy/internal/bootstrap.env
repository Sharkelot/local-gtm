# Local GTM internal deployment bootstrap
# Source this to render per-CT environment files.
# Keep this file outside the public repository.
#
# Usage:
#   source bootstrap.env
#   bash ../split/render-proxmox-envs.sh bootstrap.env /etc/cloudflared/tunnel-token.txt /etc/local-gtm/

# --- Host topology ---
CRM_HOST=10.0.0.70
DATABASE_HOST=10.0.0.71
DOCUMENT_HOST=10.0.0.72
IDENTITY_HOST=10.0.0.73
INFERENCE_WORKER_IP=10.0.0.3

# --- Admin CIDR (restricts Keycloak admin hostname) ---
PRIVATE_ADMIN_CIDR=10.0.0.0/24

# --- Public domains ---
APP_DOMAIN=crm.afterlifehigh.com
HOOKS_DOMAIN=hooks.afterlifehigh.com
KEYCLOAK_DOMAIN=auth.afterlifehigh.com
KEYCLOAK_ADMIN_DOMAIN=auth-admin.afterlifehigh.com
GRAFANA_DOMAIN=observability.afterlifehigh.com

# --- PostgreSQL ---
POSTGRES_DB=legal_crm
POSTGRES_BOOTSTRAP_USER=legal_crm_bootstrap
POSTGRES_BOOTSTRAP_PASSWORD=generate-with-openssl-rand-hex-32
POSTGRES_MIGRATION_USER=legal_crm_migrator
POSTGRES_MIGRATION_PASSWORD=generate-with-openssl-rand-hex-32
POSTGRES_RUNTIME_USER=legal_crm_runtime
POSTGRES_RUNTIME_PASSWORD=generate-with-openssl-rand-hex-32
POSTGRES_PLATFORM_USER=legal_crm_platform
POSTGRES_PLATFORM_PASSWORD=generate-with-openssl-rand-hex-32
POSTGRES_REPORTING_USER=legal_crm_reporting
POSTGRES_REPORTING_PASSWORD=generate-with-openssl-rand-hex-32
POSTGRES_KEYCLOAK_USER=keycloak
POSTGRES_KEYCLOAK_PASSWORD=generate-with-openssl-rand-hex-32

# --- Redis ---
REDIS_PASSWORD=generate-with-openssl-rand-hex-32

# --- Keycloak ---
KEYCLOAK_ADMIN=platform-admin
KEYCLOAK_ADMIN_PASSWORD=generate-with-openssl-rand-hex-32
KEYCLOAK_CLIENT_ID=legal-crm-web
KEYCLOAK_CLIENT_SECRET=generate-with-openssl-rand-hex-32

# --- NextAuth ---
NEXTAUTH_SECRET=generate-with-openssl-rand-hex-32

# --- Inference worker ---
INFERENCE_WORKER_TOKEN=generate-with-openssl-rand-hex-32
INFERENCE_WORKER_ACTOR_ID=10000000-0000-4000-8000-000000000020

# --- MinIO ---
MINIO_ROOT_USER=minio-admin
MINIO_ROOT_PASSWORD=generate-with-openssl-rand-hex-32
MINIO_DOCUMENT_BUCKET=legal-documents
MINIO_DOCUMENT_RETENTION_DAYS=365
MINIO_SCANNER_ACCESS_KEY=document-scanner
MINIO_SCANNER_SECRET_KEY=generate-with-openssl-rand-hex-32

# --- Webhook mappings ---
WEBHOOK_TRUSTED_MAPPINGS=[]
