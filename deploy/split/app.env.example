# CT 600 application split. Copy outside source control and replace every value.
# Remote endpoints must be reachable only through the approved private network/VPN.
APP_DOMAIN=crm.example.invalid
HOOKS_DOMAIN=hooks.example.invalid
KEYCLOAK_DOMAIN=auth.example.invalid
KEYCLOAK_ADMIN_DOMAIN=auth-admin.example.invalid
GRAFANA_DOMAIN=observability.example.invalid
PRIVATE_ADMIN_CIDR=192.0.2.0/24
# Remote services are never Docker-local in this topology. Use private HTTPS names
# whose certificates chain to PRIVATE_CA_BUNDLE_PATH.
KEYCLOAK_UPSTREAM=https://keycloak.private.example.invalid:8443
GRAFANA_UPSTREAM=https://grafana.private.example.invalid:3000
CLOUDFLARE_API_TOKEN=replace-with-zone-scoped-dns-token

# Absolute host path mounted read-only into Caddy, web, and platform-worker. It must
# contain only the issuing CA(s), not a private key, and be readable by Docker.
PRIVATE_CA_BUNDLE_PATH=/etc/local-gtm/ca/inter-ct-ca-bundle.pem

# Immutable release references. CADDY_IMAGE must contain the Cloudflare DNS module.
CADDY_IMAGE=registry.example.invalid/legal-crm-caddy@sha256:replace-with-release-digest
WEB_IMAGE=registry.example.invalid/legal-crm-web@sha256:replace-with-release-digest
PLATFORM_WORKER_IMAGE=registry.example.invalid/legal-crm-platform-worker@sha256:replace-with-release-digest
REDIS_IMAGE=redis:7.4.2-alpine
REDIS_PASSWORD=replace-with-long-random-password
# CT 600's private/WireGuard address only. Enforce a host/Proxmox firewall rule that
# permits TCP/6379 exclusively from the Windows inference worker and approved workers.
# Do not expose Redis through public, LAN-wide, or reverse-proxy interfaces.
REDIS_PRIVATE_BIND_ADDRESS=${CRM_HOST}

# Remote PostgreSQL roles: runtime for web requests; platform role for worker/internal calls.
DATABASE_URL=postgresql://legal_crm_runtime:replace-with-password@postgres.private.example.invalid:5432/legal_crm?schema=public&sslmode=verify-full&sslrootcert=/etc/ssl/private-ca/ca-bundle.pem
INTERNAL_DATABASE_URL=postgresql://legal_crm_platform:replace-with-password@postgres.private.example.invalid:5432/legal_crm?schema=public&sslmode=verify-full&sslrootcert=/etc/ssl/private-ca/ca-bundle.pem
PLATFORM_DATABASE_URL=postgresql://legal_crm_platform:replace-with-password@postgres.private.example.invalid:5432/legal_crm?schema=public&sslmode=verify-full&sslrootcert=/etc/ssl/private-ca/ca-bundle.pem

# Remote Keycloak/OpenBao/observability endpoints; use TLS and private DNS.
KEYCLOAK_ISSUER=https://auth.example.invalid/realms/legal-crm
KEYCLOAK_CLIENT_ID=legal-crm-web
KEYCLOAK_CLIENT_SECRET=replace-with-keycloak-client-secret
AUTH_SECRET=replace-with-32-byte-or-longer-random-secret
OPENBAO_ADDR=https://openbao.private.example.invalid:8200
OPENBAO_TOKEN=replace-with-scoped-short-lived-workload-token
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.private.example.invalid:4318

INFERENCE_WORKER_TOKEN=replace-with-worker-to-server-token
INFERENCE_WORKER_ACTOR_ID=10000000-0000-4000-8000-000000000020
# JSON only; provider subscription/channel secrets stay in the approved secret source.
WEBHOOK_TRUSTED_MAPPINGS=[]

# Remote document storage and scanner. The scanner principal is read-only to exact object versions.
MINIO_ENDPOINT=minio.private.example.invalid
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_SCANNER_ACCESS_KEY=document-scanner
MINIO_SCANNER_SECRET_KEY=replace-with-long-random-password
MINIO_DOCUMENT_BUCKET=legal-documents
# ClamAV's TCP protocol is not public/TLS-terminated here: permit this port only on
# the private inter-CT network from the platform worker's CT, and deny all other sources.
CLAMAV_HOST=clamav.private.example.invalid
CLAMAV_PORT=3310
