# Copy to a protected deployment-only environment file. Do not commit populated values.
POSTGRES_DB=legal_crm
POSTGRES_BOOTSTRAP_USER=legal_crm_bootstrap
POSTGRES_BOOTSTRAP_PASSWORD=replace-with-long-random-password
POSTGRES_MIGRATION_USER=legal_crm_migrator
POSTGRES_MIGRATION_PASSWORD=replace-with-long-random-password
POSTGRES_RUNTIME_USER=legal_crm_runtime
POSTGRES_RUNTIME_PASSWORD=replace-with-long-random-password
POSTGRES_PLATFORM_USER=legal_crm_platform
POSTGRES_PLATFORM_PASSWORD=replace-with-long-random-password
POSTGRES_REPORTING_USER=legal_crm_reporting
POSTGRES_REPORTING_PASSWORD=replace-with-long-random-password
POSTGRES_KEYCLOAK_USER=keycloak
POSTGRES_KEYCLOAK_PASSWORD=replace-with-long-random-password

# Bind only to this CT's private/VPN address. Never use 0.0.0.0.
POSTGRES_PRIVATE_BIND_ADDRESS=${DATABASE_HOST}
# Must be an immutable digest from the released migrator image.
MIGRATOR_IMAGE=registry.example.invalid/legal-crm-migrator@sha256:replace-with-release-digest

# Provision managed server.crt/server.key/root.crt in deploy/split/postgres/tls outside Git.
# server.key must be readable by the postgres container user and must not be group/world readable.
