# Copy to an access-controlled identity.env; do not commit the copy.
IDENTITY_PRIVATE_BIND_ADDRESS=10.0.0.73
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak@sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
OTEL_COLLECTOR_IMAGE=ghcr.io/open-telemetry/opentelemetry-collector-releases/opentelemetry-collector-contrib@sha256:bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb
PROMETHEUS_IMAGE=prom/prometheus@sha256:cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc
ALERTMANAGER_IMAGE=prom/alertmanager@sha256:dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd
LOKI_IMAGE=grafana/loki@sha256:eeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee
GRAFANA_IMAGE=grafana/grafana@sha256:ffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff

# These public-facing private/VPN URLs must agree with CT600's KEYCLOAK_DOMAIN
# and GRAFANA_DOMAIN. The CT600 upstream hostnames additionally need certificate
# SANs; see identity/tls/README.md.
KEYCLOAK_HOSTNAME=https://auth.example.invalid
KEYCLOAK_ADMIN_HOSTNAME=https://auth-admin.example.invalid
GRAFANA_ROOT_URL=https://observability.example.invalid

# CT601; hostname must match the certificate. Keep sslmode=verify-full in the URL.
KEYCLOAK_DATABASE_URL=jdbc:postgresql://postgres.internal.example:5432/legal_crm?sslmode=verify-full&sslrootcert=/run/postgresql-ca/root.crt
POSTGRES_KEYCLOAK_USER=replace-with-keycloak-role
POSTGRES_KEYCLOAK_PASSWORD=replace-with-secret

# Bootstrap administrator variables are intentionally absent from steady-state Compose.
# Inject KC_BOOTSTRAP_ADMIN_USERNAME/KC_BOOTSTRAP_ADMIN_PASSWORD only for the first
# controlled Keycloak start, then recreate the service without them.
GRAFANA_ADMIN_USER=replace-with-admin-user
GRAFANA_ADMIN_PASSWORD=replace-with-secret
