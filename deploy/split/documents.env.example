# Copy to a protected .env on the private documents/security CT. Never commit it.
# CT 602 owns 10.0.0.72; CT 601/data owns 10.0.0.71. Never use 0.0.0.0 here.
# Host firewall policy must allow TCP 9000, 8200, and 3310 only from app CT 600
# at 10.0.0.70, and deny those ports from every other source.
DOCUMENTS_PRIVATE_BIND_IP=10.0.0.72

# Root credentials are used only by MinIO and its one-shot bootstrap job.
MINIO_ROOT_USER=minio-admin
MINIO_ROOT_PASSWORD=replace-with-long-random-password
MINIO_DOCUMENT_BUCKET=legal-documents
MINIO_DOCUMENT_RETENTION_DAYS=365

# The uploader may create document versions; the scanner is read-only and cannot mutate objects.
MINIO_UPLOADER_ACCESS_KEY=document-uploader
MINIO_UPLOADER_SECRET_KEY=replace-with-long-random-password
MINIO_SCANNER_ACCESS_KEY=document-scanner
MINIO_SCANNER_SECRET_KEY=replace-with-long-random-password

# Required before startup. Supply a CA trusted by the app CT, plus a server certificate whose
# SAN covers the private MinIO/OpenBao names used by the app CT. These are intentionally absent.
#   deploy/split/minio/certs/public.crt
#   deploy/split/minio/certs/private.key
#   deploy/split/minio/certs/CAs/inter-ct-ca.crt
#   deploy/split/openbao/tls/tls.crt
#   deploy/split/openbao/tls/tls.key
#   deploy/split/openbao/tls/ca.crt
# OpenBao remains sealed and unconfigured after Compose starts. An operator must explicitly
# initialize/unseal it, enable KV v2 + Transit, and configure workload auth with short-lived,
# policy-scoped credentials. Do not use a root token as an application runtime credential.
# OpenBao 2.2 no longer supports mlock; disable swap on CT602 (or use an approved encrypted
# swap design) before starting the secrets service.
