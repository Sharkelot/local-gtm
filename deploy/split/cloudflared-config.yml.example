# Cloudflare Tunnel ingress configuration for Local GTM
# Copy to cloudflared-config.yml and customize for your environment.
# The setup-cloudflared-ct901.sh script generates this automatically.
#
# tunnel: <tunnel-name>
# credentials-file: /etc/cloudflared/credentials.json
# metrics: 127.0.0.1:20241
#
# ingress:
#   # CRM application - terminates TLS at Cloudflare edge, HTTPS to origin Caddy
#   - hostname: crm.example.com
#     service: https://<crm-ct-ip>:443
#     originRequest:
#       noTLSVerify: true
#
#   # Keycloak authentication (proxied through Caddy)
#   - hostname: auth.example.com
#     service: https://<crm-ct-ip>:443
#     originRequest:
#       noTLSVerify: true
#
#   # Catch-all
#   - service: http_status:404
