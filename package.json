{
  "name": "local-gtm",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --parallel --filter @local-gtm/web --filter @local-gtm/platform-worker --filter @local-gtm/inference-worker dev",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "test:integration": "pnpm -r --if-present test:integration",
    "test:e2e": "pnpm --filter @local-gtm/web test:e2e",
    "format:check": "prettier --check .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/node": "24.10.9",
    "eslint": "9.39.2",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.53.1",
    "vitest": "4.0.18"
  },
  "pnpm": {
    "overrides": {
      "sharp": "^0.35.0"
    }
  }
}
